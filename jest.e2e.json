{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^uuid$": "<rootDir>/node_modules/uuid/dist/index.js"
  },
  "testEnvironment": "node",
  "testTimeout": 30000
}
