{
  "name": "@flutchai/flutch-oss",
  "version": "0.7.0-alpha.2",
  "description": "Flutch OSS — standalone agent engine for on-premise deployment",
  "main": "dist/index.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --coverageReporters=json-summary --coverageReporters=text",
    "test:e2e": "jest --config jest.e2e.json --forceExit",
    "test:all": "yarn test:unit && yarn client:test && yarn test:e2e",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/data-source.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/data-source.ts",
    "client:install": "yarn --cwd client install",
    "client:build": "yarn --cwd client build",
    "client:dev": "yarn --cwd client dev",
    "client:test": "yarn --cwd client test",
    "dev:all": "concurrently -n api,ui -c cyan,magenta \"yarn dev\" \"yarn client:dev\""
  },
  "dependencies": {
    "@flutchai/flutch-sdk": "^0.2.7",
    "@flutchai/knowledge": "0.1.3",
    "@langchain/anthropic": "^0.3.0",
    "@langchain/core": "^1.1.30",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/openai": "^1.0.0",
    "@nestjs/axios": "^3.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^10.0.2",
    "@types/bcrypt": "^6.0.0",
    "axios": "^1.6.5",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ioredis": "^5.8.2",
    "langfuse-langchain": "^3.38.6",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/ioredis-mock": "^8",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/pg": "^8",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.42.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^uuid$": "<rootDir>/../node_modules/@langchain/langgraph-checkpoint/node_modules/uuid/dist/index.js"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/migrations/**",
      "!**/main.ts",
      "!**/data-source.ts",
      "!**/*.entity.ts",
      "!**/*.enum.ts",
      "!**/index.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "packageManager": "yarn@4.5.3"
}
