# Flutch OSS Agent Engine — Environment Configuration

# Basic
NODE_ENV=development

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=flutch
POSTGRES_PASSWORD=flutch
POSTGRES_DB=flutch_oss

# Agent config source: "local" (reads agents.json) or "platform" (fetches from Flutch API)
CONFIG_MODE=local

# Flutch Platform (required when CONFIG_MODE=platform)
API_URL=https://your-flutch-platform/api
INTERNAL_API_TOKEN=your-internal-token

# LLM Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Telegram Platform Connector (optional — only needed if using Telegram)
# Per-agent token: TELEGRAM_BOT_TOKEN_<AGENTID> (dashes → underscores, uppercase)
# Example for agent "roofing-agent":
TELEGRAM_BOT_TOKEN_ROOFING_AGENT=
# Optional: secret token for webhook verification (set same value in Telegram setWebhook call)
TELEGRAM_WEBHOOK_SECRET=

# Monitoring (optional)
LOKI_URL=http://loki:3100/loki/api/v1/push
