# Flutch OSS Agent Engine — Environment Configuration
# Copy this file to .env and fill in the values marked as required.

# ──────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# PostgreSQL connection string — used for agent state (checkpointer) and the app DB.
# Matches the postgres service in docker-compose.yml by default.
DATABASE_URL=postgresql://flutch:flutch@localhost:5444/flutch_oss

# At least one LLM provider key is required
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Admin UI — change before deploying
ADMIN_PASSWORD=changeme
ADMIN_JWT_SECRET=change-this-to-a-random-secret

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL
# ──────────────────────────────────────────────────────────────────────────────

PORT=3000

# Agent config source:
#   local    — reads agents.json from disk (default, recommended for self-hosted)
#   platform — fetches from Flutch Cloud API
CONFIG_MODE=local

# MCP Runtime — tool execution proxy (included in docker-compose.yml)
MCP_RUNTIME_URL=http://localhost:3004

# Webhook base URL — required only if using Telegram or other webhook-based connectors
# WEBHOOK_BASE_URL=https://your-server.com

# Telegram — one token per agent, named TELEGRAM_BOT_TOKEN_<AGENT_ID>
# (replace dashes with underscores, uppercase)
# Example for agent "roofing-agent":
# TELEGRAM_BOT_TOKEN_ROOFING_AGENT=
# TELEGRAM_WEBHOOK_SECRET=    # for webhook signature verification

# LangFuse — LLM tracing dashboard (optional)
# LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=http://localhost:3025

# Web search via MCP Runtime (Tavily)
# TAVILY_API_KEY=tvly-...

# Flutch Platform API (only needed when CONFIG_MODE=platform)
# API_URL=https://api.flutch.ai
# INTERNAL_API_TOKEN=
