{
  "type": "object",
  "properties": {
    "systemPrompt": {
      "type": "string",
      "title": "System Prompt",
      "format": "textarea",
      "default": "You are a helpful AI assistant."
    },
    "modelId": {
      "type": "modelSelector",
      "title": "Model",
      "params": {
        "modelType": "chat",
        "isActive": true
      }
    },
    "temperature": {
      "type": "number",
      "title": "Temperature",
      "default": 0.7,
      "minimum": 0,
      "maximum": 1
    },
    "maxTokens": {
      "type": "integer",
      "title": "Max Tokens",
      "default": 2000,
      "minimum": 100,
      "maximum": 4000,
      "description": "Maximum tokens in response"
    },
    "availableTools": {
      "type": "toolSelector",
      "title": "Available Tools",
      "description": "Select which tools the agent can use during conversations",
      "params": {
        "isMulti": true,
        "showDescriptions": true
      }
    }
  },
  "required": ["systemPrompt", "modelId"]
}
